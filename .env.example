# 复制为 .env 并填入你的 API Key
# 火山引擎示例：
DASHSCOPE_API_KEY=your-api-key-here
DASHSCOPE_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/chat/completions
DASHSCOPE_MODEL=glm-4-7-251222

# 阿里云 DashScope 示例：
# DASHSCOPE_API_KEY=sk-xxxxxxxx
# DASHSCOPE_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
# DASHSCOPE_MODEL=qwen-plus

# 和风天气（https://dev.qweather.com）
# 在控制台「设置」中复制你的 API Host，例如 abc1234xyz.def.qweatherapi.com
QWEATHER_API_KEY=your-qweather-api-key
QWEATHER_API_HOST=your-api-host.qweatherapi.com
# 默认城市 LocationID（广州 101280101），未定位时使用
QWEATHER_DEFAULT_LOCATION=101280101
